# -*- coding: utf-8 -*-
"""
Created on Tue Mar 10 10:08:23 2026
Updated Random Forest for Area_Irrigated with train/test split, cross-validation,
and feature importance stability across folds
"""

import pandas as pd
import numpy as np
from sklearn.ensemble import RandomForestRegressor
from sklearn.impute import SimpleImputer
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline
from sklearn.metrics import r2_score, mean_squared_error, mean_absolute_error
from sklearn.model_selection import train_test_split, KFold
import matplotlib.pyplot as plt
import seaborn as sns

# === Step 1: Load the data ===
file_path = r"C:\.xlsx"
df = pd.read_excel(file_path)

# === Step 2: Define variables ===
features = ['Workers', 'Localized', 'Sprinkler', 'Land_price', 'Precip', 'TMAX']
target = 'Area_Irrigated'

# Drop rows with missing values
df_rf = df[features + [target]].dropna()
X = df_rf[features]
y = df_rf[target]

# === Step 3: Train/Test split (70/30) ===
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.30, random_state=42
)

# === Step 4: Build pipeline ===
pipeline = Pipeline([
    ('imputer', SimpleImputer(strategy='mean')),
    ('scaler', StandardScaler()),
    ('rf', RandomForestRegressor(n_estimators=100, random_state=42, n_jobs=-1))
])

# === Step 5: Train model on training set ===
pipeline.fit(X_train, y_train)

# === Step 6: Predict on test set ===
y_pred = pipeline.predict(X_test)

# === Step 7: Evaluate model performance on test set ===
r2 = r2_score(y_test, y_pred)
mse = mean_squared_error(y_test, y_pred)
rmse = np.sqrt(mse)
mae = mean_absolute_error(y_test, y_pred)

# === Step 8: Cross-validation for robustness + importance stability ===
kf = KFold(n_splits=5, shuffle=True, random_state=42)
cv_r2_scores = []
importance_list = []

for train_idx, test_idx in kf.split(X):
    X_cv_train, X_cv_test = X.iloc[train_idx], X.iloc[test_idx]
    y_cv_train, y_cv_test = y.iloc[train_idx], y.iloc[test_idx]
    
    pipeline.fit(X_cv_train, y_cv_train)
    
    # CV R²
    y_cv_pred = pipeline.predict(X_cv_test)
    cv_r2_scores.append(r2_score(y_cv_test, y_cv_pred))
    
    # Save fold importances
    rf_fold = pipeline.named_steps['rf']
    importance_list.append(rf_fold.feature_importances_)

# Compute CV R² mean and std
cv_mean = np.mean(cv_r2_scores)
cv_std = np.std(cv_r2_scores)

# Compute importance stability across folds
importance_array = np.array(importance_list)  # shape: (n_folds, n_features)
importance_mean = np.mean(importance_array, axis=0)
importance_std = np.std(importance_array, axis=0)
importance_stability_df = pd.DataFrame({
    'Feature': features,
    'Importance_Mean': importance_mean,
    'Importance_STD': importance_std
}).sort_values(by='Importance_Mean', ascending=False)

# === Step 9: Feature importance from full model ===
rf_model = pipeline.named_steps['rf']
importances = pd.Series(rf_model.feature_importances_, index=features).sort_values(ascending=False)

# === Step 10: Output directory ===
output_dir = r"C:"

# Save feature importances from full model
importances_df = pd.DataFrame(importances, columns=['Importance'])
importances_df.to_excel(
    f"{output_dir}\\Random_Forest_Feature_Importance_IrrigatedArea.xlsx",
    index_label='Variable'
)

# Save feature importance stability (mean ± std across folds)
importance_stability_df.to_excel(
    f"{output_dir}\\Random_Forest_Feature_Importance_Stability_IrrigatedArea.xlsx",
    index=False
)

# Save performance metrics
metrics_df = pd.DataFrame({
    'Metric': ['R-squared', 'MSE', 'RMSE', 'MAE'],
    'Value': [r2, mse, rmse, mae]
})
metrics_df.to_excel(
    f"{output_dir}\\Random_Forest_Model_Performance_IrrigatedArea.xlsx",
    index=False
)

# Save cross-validation results
cv_df = pd.DataFrame({'Metric': ['CV_R2_mean', 'CV_R2_std'], 'Value': [cv_mean, cv_std]})
cv_df.to_excel(
    f"{output_dir}\\Random_Forest_CrossValidation_IrrigatedArea.xlsx",
    index=False
)

# === Step 11: Plot feature importances ===
plt.figure(figsize=(8,5))
sns.barplot(x=importances.values, y=importances.index)
plt.title("Random Forest Feature Importance: Area Irrigated")
plt.xlabel("Importance Score")
plt.ylabel("Variable")
plt.tight_layout()
plt.show()
